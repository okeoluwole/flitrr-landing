# Supabase project credentials (Settings, API in the Supabase Dashboard)
# Copy this file to .env.local and fill in the values. .env.local is
# gitignored. The same keys must also be set in the Vercel project's
# Environment Variables for production deployments.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only keys for the weekly digest (M7.3). Never NEXT_PUBLIC_.
# SUPABASE_SECRET_KEY: the secret API key (Settings, API). The digest cron
#   and the unsubscribe route run with no user session, so they need it to
#   read and write past RLS.
# RESEND_API_KEY: from resend.com, after verifying the flitrr.com domain.
# CRON_SECRET: any long random string. Vercel cron sends it as the bearer
#   token; the digest route rejects requests without it.
# UNSUBSCRIBE_SECRET: any long random string. Signs the unsubscribe tokens
#   in digest emails.
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
CRON_SECRET=
UNSUBSCRIBE_SECRET=
